# =============================================================================
# Provider API keys
# =============================================================================

# Used by the chat and title-generation agents.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Used for document page embeddings during ingestion and query embeddings during retrieval.
# The google-genai SDK reads this automatically.
GOOGLE_API_KEY=your_google_api_key_here

# Required only for sandbox-backed file generation/download workflows.
E2B_API_KEY=your_e2b_api_key_here


# =============================================================================
# API service
# =============================================================================

API_PORT=8000
CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173"]'


# =============================================================================
# Main application database
# =============================================================================

POSTGRES_USER=orbital
POSTGRES_PASSWORD=orbital
POSTGRES_DB=orbital_takehome
DATABASE_URL=postgresql+asyncpg://orbital:orbital@db:5432/orbital_takehome


# =============================================================================
# Document ingestion and retrieval
# =============================================================================

# Redis-backed RQ queue shared by the API and ingestion worker.
REDIS_URL=redis://redis:6379/0

# Gemini Embedding 2 supports multimodal PDF page embeddings.
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIM=1536
EMBEDDING_CONCURRENCY=32

# The QA agent reads document chunks from the main app database using psycopg.
RAG_DATABASE_URL=postgresql://orbital:orbital@db:5432/orbital_takehome


# =============================================================================
# Agent service
# =============================================================================

AEGRA_PORT=2026
AEGRA_DB_PORT=5433
