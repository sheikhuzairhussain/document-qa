ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Google Gemini API key. Used for document-chunk embeddings (ingestion worker)
# and query embeddings (agent). Read automatically by the google-genai SDK.
GOOGLE_API_KEY=your_google_api_key_here
E2B_API_KEY=your_e2b_api_key_here
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://orbital:orbital@db:5432/orbital_takehome
POSTGRES_USER=orbital
POSTGRES_PASSWORD=orbital
POSTGRES_DB=orbital_takehome
CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173"]'

# Document ingestion pipeline
# Redis-backed RQ queue the API enqueues to and the worker consumes from.
REDIS_URL=redis://redis:6379/0
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIM=1536
EMBEDDING_CONCURRENCY=32

# Aegra agent stack
AEGRA_PORT=2026
AEGRA_DB_PORT=5433
# The qa-agent reads document chunks from the main app DB (sync driver).
RAG_DATABASE_URL=postgresql://orbital:orbital@db:5432/orbital_takehome
